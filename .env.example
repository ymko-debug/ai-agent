# Copy this file to .env and fill in your API keys.
# Never share your .env file or commit it to Git.

# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional — fallback provider. Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — enables web search. Free tier at https://tavily.com
TAVILY_API_KEY=

# Optional — NVIDIA NIM free-tier models. Get from https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
